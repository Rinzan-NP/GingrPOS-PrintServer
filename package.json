{
    "name": "gingr-pos-print-server",
    "version": "1.0.0",
    "description": "GingrPOS Local Print Server — silent thermal printer bridge, no browser Allow prompts",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "start:server": "node server.js",
        "build": "electron-builder",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build:linux": "electron-builder --linux"
    },
    "author": "GingrPOS",
    "license": "MIT",
    "dependencies": {
        "body-parser": "^1.20.2",
        "cors": "^2.8.5",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.gingrpos.printserver",
        "productName": "GingrPOS Print Server",
        "copyright": "GingrPOS",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "server.js",
            "package.json",
            "icon.png",
            "utils/**/*",
            "driver/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "icon.icns"
        },
        "linux": {
            "target": "AppImage",
            "icon": "icon.png"
        },
        "nsis": {
            "oneClick": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "runAfterFinish": true,
            "shortcutName": "GingrPOS Print Server"
        }
    }
}
